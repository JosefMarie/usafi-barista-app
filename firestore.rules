rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is CEO
    function isCEO() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ceo' ||
              request.auth.token.email == 'ceo@usafi.com'); // Fallback if document missing
    }
    
    // Helper function to check if user is staff
    function isStaff() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'instructor', 'ceo', 'manager'];
    }
    
    // Helper function to check if user is admin or CEO
    function isAdminOrCEO() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'ceo'];
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if true; 
      allow create: if true; 
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdminOrCEO());
      allow delete: if isAdminOrCEO();
      
      match /progress/{progressId} {
        allow read: if true;
        allow write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      }
      
      match /business_progress/{courseId} {
        allow read: if true;
        allow write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      }
      
      match /weekend_progress/{moduleId} {
        allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
        allow write: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      }
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isStaff();
      
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isStaff();
      }
      
      match /lessons/{lessonId} {
        allow read: if true;
        allow write: if isStaff();
      }
    }
    
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /quiz_submissions/{submissionId} {
      allow read: if isAuthenticated() && 
                    (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isStaff();
    }
    
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /job_opportunities/{jobId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /equipment/{itemId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /testimonials/{testimonialId} {
      allow read: if isStaff() || (resource.data.status == 'approved');
      allow create: if true;
      allow update, delete: if isStaff();
    }
    
    match /forum_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.authorId == request.auth.uid || isStaff());
    }
    
    match /forum_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.authorId == request.auth.uid || isStaff());
    }
    
    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
    
    match /chats/{chatId} {
      allow read, write: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && 
                    (resource.data.userId == request.auth.uid || resource.data.recipientId == 'ceo');
      allow create: if isStaff();
      allow update, delete: if isAuthenticated() && 
                               (resource.data.userId == request.auth.uid || isStaff());
    }
    
    match /videos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    
    match /activity/{activityId} {
      allow read: if isStaff();
      allow create: if isAuthenticated();
      allow update, delete: if isStaff();
    }
    
    match /subscribers/{subscriberId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isStaff();
    }
    
    match /contact_messages/{messageId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isStaff();
    }
    
    match /password_reset_tokens/{tokenId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    match /business_courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
      
      match /chapters/{chapterId} {
        allow read: if isAuthenticated();
        allow write: if isStaff();
      }
      
      match /modules/{moduleId} {
        allow read: if isAuthenticated();
        allow write: if isStaff();
      }
    }
    
    match /system_settings/{settingId} {
      allow read: if true;
      allow write: if isAdminOrCEO();
    }
    
    match /weekend_bookings/{bookingId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isStaff();
    }
    
    match /weekend_module_cards/{moduleId}/cards/{cardId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    
    match /donations/{donationId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isStaff();
    }
 
    match /weekend_media/{mediaId} {
      allow read: if true;
      allow write: if isStaff();
    }
 
    match /system_announcements/{announcementId} {
      allow read: if true;
      allow write: if isCEO();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
